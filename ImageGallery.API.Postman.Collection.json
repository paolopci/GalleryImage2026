              "const json = pm.response.json();",
              "pm.test(\"Il titolo aggiornato e' quello atteso\", function () {",
              "    pm.expect(json.title).to.eql(pm.collectionVariables.get(\"updatedImageTitle\"));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerTokenWrite}}",
            "type": "text"
          },
