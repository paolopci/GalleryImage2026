            "exec": [
              "pm.test(\"Status code 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test(\"La risposta contiene access_token\", function () {",
              "    pm.expect(json).to.have.property(\"access_token\");",
              "});",
              "",
              "pm.collectionVariables.set(\"bearerTokenWrite\", json.access_token);",
              "pm.collectionVariables.set(\"bearerTokenWriteScope\", json.scope || \"\");",
              "pm.collectionVariables.set(\"bearerTokenWriteType\", json.token_type || \"\");",
              "if (pm.environment) {",
              "    pm.environment.set(\"bearerTokenWrite\", json.access_token);",
              "    pm.environment.set(\"bearerTokenWriteScope\", json.scope || \"\");",
              "    pm.environment.set(\"bearerTokenWriteType\", json.token_type || \"\");",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "type": "text"
          },
          {
            "key": "Accept",
