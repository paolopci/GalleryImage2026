              "type": "text"
            },
            {
              "key": "username",
              "value": "Emma",
              "type": "text"
            },
            {
              "key": "password",
              "value": "Micene@65",
              "type": "text"
            },
            {
              "key": "scope",
              "value": "openid profile roles paese imagegalleryapi.write",
              "type": "text"
            }
          ]
