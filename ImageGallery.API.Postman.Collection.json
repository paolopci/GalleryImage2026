          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code 204\", function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "pm.collectionVariables.set(\"deletedImageId\", pm.collectionVariables.get(\"createdImageId\"));"
