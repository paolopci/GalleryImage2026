          "path": [
            "api",
            "images",
            "{{createdImageId}}"
          ]
        },
        "description": "Verifica il nuovo titolo solo sull'immagine creata da Emma al test 04 e aggiornata al test 06, usando createdImageId."
      },
      "response": []
    },
    {
      "name": "08 - DELETE immagine creata da Emma al test 04 rimuove la risorsa usando createdImageId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code 204\", function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "const deletedImageId = pm.collectionVariables.get(\"createdImageId\") || (pm.environment ? pm.environment.get(\"createdImageId\") : \"\");",
              "pm.collectionVariables.set(\"deletedImageId\", deletedImageId);",
              "if (pm.environment) {",
              "    pm.environment.set(\"deletedImageId\", deletedImageId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerTokenWrite}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/images/{{createdImageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "images",
            "{{createdImageId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "09 - GET immagine eliminata da Emma verifica 403 usando deletedImageId dal test precedente",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code 403\", function () {",
              "    pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearerTokenWrite}}",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/images/{{deletedImageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "images",
            "{{deletedImageId}}"
          ]
        },
        "description": "Verifica in 403 solo l'immagine creata da Emma al test 04 e cancellata al test 08, usando automaticamente deletedImageId. L'API applica prima il controllo di ownership tramite MustOwnImage, quindi su una risorsa non piu' posseduta/non piu' disponibile il comportamento osservabile e' Forbid."
      },
      "response": []
