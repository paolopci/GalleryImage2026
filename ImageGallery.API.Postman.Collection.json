{
  "info": {
    "_postman_id": "4d3b84f3-7b6d-4f13-b346-6a9324e9e2f7",
    "name": "ImageGallery API - IdentityServer Ordered Tests",
    "description": "Collection Postman per test manuali ordinati della ImageGallery API usando reference token emessi dall'IdentityServer locale. Il blocco iniziale valida il profilo read-only di David, mentre il blocco CRUD successivo usa il token write di Emma e opera solo sull'immagine creata durante il test 04.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1.1 - LOGIN David ottiene token read dall'IDP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test(\"La risposta contiene access_token\", function () {",
              "    pm.expect(json).to.have.property(\"access_token\");",
              "});",
              "",
              "pm.collectionVariables.set(\"bearerTokenRead\", json.access_token);",
              "pm.collectionVariables.set(\"bearerTokenReadScope\", json.scope || \"\");",
              "pm.collectionVariables.set(\"bearerTokenReadType\", json.token_type || \"\");",
              "if (pm.environment) {",
              "    pm.environment.set(\"bearerTokenRead\", json.access_token);",
              "    pm.environment.set(\"bearerTokenReadScope\", json.scope || \"\");",
              "    pm.environment.set(\"bearerTokenReadType\", json.token_type || \"\");",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "client_id",
              "value": "{{postmanClientId}}",
              "type": "text"
            },
            {
              "key": "client_secret",
              "value": "{{postmanClientSecret}}",
              "type": "text"
            },
            {
              "key": "grant_type",
              "value": "password",
              "type": "text"
            },
            {
              "key": "username",
              "value": "David",
              "type": "text"
            },
            {
              "key": "password",
              "value": "Micene@65",
              "type": "text"
            },
            {
              "key": "scope",
              "value": "openid profile roles paese imagegalleryapi.read",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{identityServerUrl}}/connect/token",
          "host": [
            "{{identityServerUrl}}"
          ],
          "path": [
            "connect",
            "token"
          ]
        },
        "description": "Ottiene dall'IdentityServer il token read da riusare nei test successivi."
      },
      "response": []
    },
    {
      "name": "1.2 - LOGIN Emma ottiene token write dall'IDP",
      "event": [
        {
