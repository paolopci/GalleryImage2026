@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@model ImageGallery.Client.ViewModels.GalleryIndexViewModel

@{
    var imageGalleryApiRoot = Configuration["ImageGalleryAPIRoot"]?.TrimEnd('/') ?? string.Empty;
}

<div class="bottomMarginDefault">

</div>
<div class="container">
    <div class="row g-4 gallery-grid">
        @foreach (var item in Model.Images)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm gallery-card">
                    <img class="card-img-top gallery-card-image" src="@($"{imageGalleryApiRoot}/images/{item.FileName}")" alt="@item.Title" />
                    <div class="card-body d-flex flex-column gallery-card-body">
                        <div class="h6 mb-3">@item.Title</div>
                        <div class="d-flex flex-wrap gap-2 mt-auto">
                            <a asp-action="EditImage" asp-controller="Gallery" asp-route-id="@item.Id">Edit title</a>
                            <span>|</span>
                            <a asp-action="DeleteImage" asp-controller="Gallery" asp-route-id="@item.Id">Delete title</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
